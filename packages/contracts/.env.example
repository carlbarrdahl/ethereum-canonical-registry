# Sepolia Testnet Configuration
# RPC URL for Sepolia network
# Get a free RPC endpoint from Alchemy, Infura, or other providers
SEPOLIA_RPC_URL=

# Private key for deploying contracts to Sepolia
# NEVER commit this file with a real private key
SEPOLIA_PRIVATE_KEY=

# Ethereum Mainnet Configuration (for production deployments)
MAINNET_RPC_URL=
MAINNET_PRIVATE_KEY=

# Etherscan API Key (for contract verification)
# Get your API key from https://etherscan.io/myapikey
ETHERSCAN_API_KEY=

# Fallback private key (used if network-specific key not set)
PRIVATE_KEY=
