{
  "name": "@ethereum-entity-registry/sdk",
  "version": "0.1.0",
  "type": "module",
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "rm -rf dist && tsup src/index.ts --format esm --dts --external @urql/core",
    "dev": "tsup src/index.ts --watch --format esm --dts --external @urql/core",
    "check-types": "tsc --noEmit",
    "prepublishOnly": "bun run build",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./package.json": "./package.json"
  },
  "types": "./dist/index.d.ts",
  "dependencies": {
    "@urql/core": "^6.0.1"
  },
  "publishConfig": {
    "access": "public"
  },
  "peerDependencies": {
    "@tanstack/react-query": ">=5.0.0",
    "react": "^19.2.4",
    "sonner": ">=1.0.0",
    "typescript": ">=4.5.0",
    "viem": "^2.45.1",
    "wagmi": ">=2.0.0"
  },
  "devDependencies": {
    "@ethereum-entity-registry/contracts": "workspace:*",
    "@types/react": "^19.2.13",
    "@types/react-dom": "^19.2.3",
    "tsup": "^8.5.1",
    "vitest": "^4.0.18"
  }
}
