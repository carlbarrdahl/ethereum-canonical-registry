# Ponder Configuration
# Set NODE_ENV=development to index local chain, otherwise indexer uses production chains

# RPC URLs per chain ID
# Local Anvil (chain ID: 31337)
PONDER_RPC_URL_31337=http://127.0.0.1:8545

# Sepolia Testnet (chain ID: 11155111)
PONDER_RPC_URL_11155111=
PONDER_RPC_URL_84532=

# Ethereum Mainnet (chain ID: 1)
PONDER_RPC_URL_1=

# RPC API Keys (used as primary providers if set)
INFURA_API_KEY=
ALCHEMY_API_KEY=

# Database (optional - uses SQLite by default)
DATABASE_URL=

# IPFS Gateway (for metadata fetching)
PINATA_GATEWAY_URL=
PINATA_GATEWAY_KEY=
