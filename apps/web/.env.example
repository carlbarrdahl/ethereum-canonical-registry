# Vercel Blob Storage
# Required for image uploads (strategy metadata images)
BLOB_READ_WRITE_TOKEN=

# WalletConnect Project ID
# Get your project ID from https://cloud.walletconnect.com/
NEXT_PUBLIC_WALLETCONNECT_PROJECT_ID=

# Sepolia RPC URL (optional - defaults to public RPC if not set)
# For better reliability, use a dedicated RPC provider like Alchemy or Infura
NEXT_PUBLIC_SEPOLIA_RPC_URL=
